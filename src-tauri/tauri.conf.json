{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ferrofluid Voice",
  "version": "1.0.0",
  "identifier": "com.ferrofluid.voice",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ferrofluid Voice",
        "width": 330,
        "height": 60,
        "minWidth": 330,
        "minHeight": 60,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": true,
        "windowEffects": {
          "effects": ["acrylic"],
          "color": "#FFFFFF70"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "copyright": "Copyright Ferrofluid Voice",
    "shortDescription": "Local dictation and transcription utility",
    "longDescription": "Ferrofluid Voice records microphone audio and transcribes it locally with a Whisper model.",
    "resources": [
      "binaries/**/*"
    ]
  }
}
